          "type": "text",
          "props": {
            "content": "Pathfinding, decision-making, and combat tactics layered on a state machine — patrol, chase, attack. Tuning was the long pole; the framework was the easy part.",
            "variant": "body",
            "align": "left",
            "color": "foreground",
            "transform": "none"
          }
        }
      ]
    },
