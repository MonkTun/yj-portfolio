          "type": "text",
          "props": {
            "content": "Weapons and projectile families that the skill tree extends. Each attribute is modulated by player stats and skills, so two builds with the same weapon can play very differently.",
            "variant": "body",
            "align": "left",
            "color": "foreground",
            "transform": "none"
          }
        }
