          "layout": { "col": 2, "colSpan": 10, "row": 5, "rowSpan": 20 },
          "type": "text",
          "props": {
            "content": "A dungeon generator that composes modular rooms, enemy distributions, and item placements differently every run. Replayability is the genre's promise; ProcGen is how you keep it.",
            "variant": "body",
            "align": "left",
            "color": "foreground",
            "transform": "none"
          }
        }
      ]
    },
