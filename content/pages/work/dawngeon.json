          "props": {
            "content": "A save system that survives the realities of mobile — phone calls, battery deaths, the App Switcher. You can stop mid-run and pick up exactly where you left off.",
            "variant": "body",
            "align": "left",
            "color": "foreground",
            "transform": "none"
          }
